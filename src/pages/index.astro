---
import Layout from "@/layouts/Layout.astro"

import About from "@/components/sections/About.astro"
import Education from "@/components/sections/Education.astro"
import Experience from "@/components/sections/Experience.astro"
import Hero from "@/components/sections/Hero.astro"
import Projects from "@/components/sections/Projects.astro"
import Languages from "@/components/sections/Languages.astro"
import Skills from "@/components/sections/Skills.astro"
import KeyboardManager from "@/components/KeyboardManager.astro"

import { basics } from "@cv"
import Certificates from "@/components/sections/Certificates.astro"
const { name, label } = basics
---

<Layout title={`Portfolio - ${name} - ${label}`}>
  <main id="pdf-content">
    <Hero />
    <About />
    <Experience />
    <Education />
    <Projects />
    <Certificates />
    <Languages />
    <Skills />
  </main>

  <!-- <button id="export-pdf-btn" class="export-btn">Export to PDF</button> -->

  <KeyboardManager />
</Layout>

<style>
  main {
    padding: 4rem;
    margin: auto;
    width: 100%;
  }

  .export-btn {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    padding: 0.75rem 1.5rem;
    background-color: #333;
    color: #fff;
    border: none;
    border-radius: 0.5rem;
    font-size: 1rem;
    cursor: pointer;
    transition: background-color 0.3s ease;
    z-index: 1000;
  }

  .export-btn:hover {
    background-color: #555;
  }

  @media (width <= 700px) {
    main {
      padding: 2rem;
    }

    .export-btn {
      bottom: 1rem;
      right: 1rem;
      padding: 0.5rem 1rem;
      font-size: 0.875rem;
    }
  }
</style>

---
import Section from "../Section.astro"
import { work } from "@cv"

type WorkEntry = (typeof work)[number]
interface CompanyGroup {
  name: string
  url: string
  positions: WorkEntry[]
}

const companies: CompanyGroup[] = []
work.forEach((job) => {
  const existing = companies.find((c) => c.name === job.name)
  if (existing) {
    existing.positions.push(job)
  } else {
    companies.push({ name: job.name, url: job.url, positions: [job] })
  }
})

const formatDate = (dateStr: string | null): string => {
  if (!dateStr) return "Present"
  const date = new Date(dateStr)
  return date.toLocaleDateString("en-US", { month: "short", year: "numeric", timeZone: "UTC" })
}
---

<Section title="Work Experience">
  <ul>
    {
      companies.map(({ name, url, positions }) => {
        const isGrouped = positions.length > 1

        if (isGrouped) {
          return (
            <li>
              <article>
                <header class="company-only">
                  <h3>
                    <a href={url} title={`View ${name}`} target="_blank">
                      {name}
                    </a>
                  </h3>
                </header>
                <ul class="positions">
                  {
                    positions.map(({ position, location, jobType, startDate, endDate, summary, highlights }) => {
                      return (
                        <li>
                          <div class="position-header">
                            <div>
                              <h4>{position}</h4>
                              {(location || jobType) && (
                                <div class="meta">
                                  {location && <span class="location">{location}</span>}
                                  {location && jobType && <span class="separator">·</span>}
                                  {jobType && <span class="job-type">{jobType}</span>}
                                </div>
                              )}
                            </div>
                            <div>
                              <time datetime={startDate} data-title={startDate}>{formatDate(startDate)}</time>
                              {" - "}
                              <time datetime={endDate ?? undefined} data-title={endDate ?? undefined}>{formatDate(endDate)}</time>
                            </div>
                          </div>
                          <footer>
                            <p>{summary}</p>
                            {highlights.map((highlight) => <span>{highlight}</span>)}
                          </footer>
                        </li>
                      )
                    })
                  }
                </ul>
              </article>
            </li>
          )
        }

        const { position, location, jobType, startDate, endDate, summary, highlights } = positions[0]

        return (
          <li>
            <article>
              <header>
                <div>
                  <h3>
                    <a href={url} title={`View ${name}`} target="_blank">
                      {name}
                    </a>
                  </h3>
                  {(location || jobType) && (
                    <div class="meta">
                      {location && <span class="location">{location}</span>}
                      {location && jobType && <span class="separator">·</span>}
                      {jobType && <span class="job-type">{jobType}</span>}
                    </div>
                  )}
                  <h4>{position}</h4>
                </div>
                <div>
                  <time datetime={startDate} data-title={startDate}>{formatDate(startDate)}</time>
                  {" - "}
                  <time datetime={endDate ?? undefined} data-title={endDate ?? undefined}>{formatDate(endDate)}</time>
                </div>
              </header>
              <footer>
                <p>{summary}</p>
                {highlights.map((highlight) => <span>{highlight}</span>)}
              </footer>
            </article>
          </li>
        )
      })
    }
  </ul>
</Section>

<style>
  ul {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  ul.positions {
    gap: 20px;
    margin-top: 8px;
    padding-left: 14px;
    border-left: 2px solid #e5e7eb;
  }

  .company-only {
    margin-bottom: 4px;
  }

  .position-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 4px;
  }

  .meta {
    display: flex;
    align-items: center;
    gap: 4px;
    margin-top: 2px;
  }

  .location,
  .job-type {
    color: #666;
    font-size: 0.75rem;
  }

  .separator {
    color: #999;
    font-size: 0.75rem;
  }

  article h3 {
    font-weight: 500;
    color: #111;
  }

  article a {
    color: #111;
  }

  article a:hover {
    text-decoration: underline;
  }

  article h4 {
    color: #222;
    font-weight: 400;
  }

  header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 4px;
  }

  time {
    color: #555;
    font-size: 0.85rem;
    min-width: 102px;
    cursor: default;
  }

  footer {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    font-size: 0.6rem;
  }

  footer span {
    border-radius: 6px;
    background: #eee;
    color: #444;
    font-size: 0.6rem;
    font-weight: 500;
    padding: 0.2rem 0.6rem;
  }

  [data-title]:hover:after {
    opacity: 1;
    transition: all 0.1s ease-in-out 0.5s;
    visibility: visible;
  }

  [data-title]:after {
    content: attr(data-title);
    background-color: #333;
    color: #fff;
    font-size: .75rem;
    font-family: Menlo, Monaco, Lucida Console, "Courier New", monospace;;
    position: absolute;
    padding: .2rem .5rem;
    bottom: -1.4rem;
    left: 50%;
    white-space: nowrap;
    box-shadow: 1px 1px 1px #222222;
    opacity: 0;
    border: 1px solid #111111;
    z-index: 99999;
    visibility: hidden;
    border-radius: 6px;
  }

  [data-title] {
    position: relative;
  }

  @media (width <= 700px) {
    time {
      text-align: right;
    }
  }
</style>

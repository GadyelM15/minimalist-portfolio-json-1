---
import Section from "../Section.astro"
import { languages } from "@cv"

---

<Section title="Languages">
  <ul>
    {
      languages.map(({ language, fluency }) => {
        return (
          <li>
            {/* making language and fluency more visually distinct */}
            <span class="language">{language}</span> - <span class="fluency">{fluency}</span>
          </li>
        )
      })
    }
  </ul>
</Section>

<style>
  ul {
    display: inline-flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  li {
    align-items: center;
    background: #eee;
    border-radius: 6px;
    color: black;
    display: flex;
    font-size: 0.8rem;
    font-weight: 500;
    gap: 4px;
    padding: 0.2rem 0.6rem;
  }
  .language {
    /* font-weight: 600; */
  }
  .fluency {
    font-style: italic;
    color: #555;
  }
  
</style>
